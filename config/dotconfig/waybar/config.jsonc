{
    "layer": "bottom",
    "position": "top",
    "height": 55,
    "spacing": 6,
    "exclusive": true,
    "modules-left": [
        "hyprland/workspaces"
    ],

    "modules-center": [ 
        "cpu",
        "memory"
    ],

    "modules-right": [
        "idle_inhibitor",
        "pulseaudio",
        "clock",
        "hyprland/language",
        "tray",
        "custom/power"
    ],

    "include": [
        "~/.config/waybar/modules.json"
    ]
}
